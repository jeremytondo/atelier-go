#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# Atelier Client
# Local CLI for initiating remote development sessions.
# =============================================================================

# --- Configuration ---

# Allow overriding via environment variables
HOST="${ATELIER_HOST:-localhost}"
SERVER_PATH="${ATELIER_REMOTE_PATH:-~/.local/bin/atelier-server}"

# Available actions
ACTIONS=("edit" "shell" "opencode")

# --- Utilities ---

log_error() {
  printf "Error: %s\n" "$1" >&2
}

check_dependencies() {
  local missing=0
  for cmd in ssh fzf; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      log_error "Missing required command: $cmd"
      missing=1
    fi
  done
  if [[ $missing -eq 1 ]]; then
    exit 1
  fi
}

# --- Commands ---

cmd_interactive_launch() {
  local mode="${1:-}"
  local prompt_text="Locations (Recents) ➜ "
  local locations_arg=""

  if [[ "$mode" == "-all" || "$mode" == "all" ]]; then
    locations_arg="all"
    prompt_text="Locations (All) ➜ "
  fi

  # Fetch locations from remote
  local raw_paths
  if ! raw_paths=$(ssh -q "$HOST" "$SERVER_PATH locations $locations_arg" 2>/dev/null); then
    log_error "Failed to fetch locations from $HOST."
    log_error "Make sure '$SERVER_PATH' exists on the remote host."
    exit 1
  fi

  if [[ -z "$raw_paths" ]]; then
    log_error "No locations found on $HOST."
    exit 1
  fi

  # Select location
  local location
  location=$(echo "$raw_paths" | fzf \
    --height=40% \
    --layout=reverse \
    --border \
    --prompt="$prompt_text" \
    --header="Select Location" || true)

  if [[ -z "$location" ]]; then
    exit 0
  fi

  # Fetch available actions
  local raw_actions
  if ! raw_actions=$(ssh -q "$HOST" "$SERVER_PATH actions \"$location\"" 2>/dev/null); then
    log_error "Failed to fetch actions from $HOST."
    exit 1
  fi

  # Select action
  local action
  action=$(echo "$raw_actions" | fzf \
    --height=20% \
    --layout=reverse \
    --border \
    --prompt="Action ➜ " \
    --header="Select Action for $(basename "$location")" || true)

  if [[ -z "$action" ]]; then
    exit 0
  fi

  # Launch
  cmd_direct_launch "$location" "$action"
}

cmd_direct_launch() {
  local location="${1:-}"
  local action="${2:-}"

  if [[ -z "$location" || -z "$action" ]]; then
    log_error "Usage: direct <location> <action>"
    exit 1
  fi

  # Launch remote session
  # -t forces TTY allocation which is required for interactive sessions (vim, shell)
  exec ssh -t "$HOST" "$SERVER_PATH session \"$location\" \"$action\""
}

usage() {
  cat <<EOF
Usage: $(basename "$0") [command] [args...]

Commands:
    launch [-all]              Interactive launcher (default)
    direct <location> <action> Connect to specific location directly
    
Environment:
    ATELIER_HOST               Remote SSH host (default: $HOST)
    ATELIER_REMOTE_PATH        Remote server script path (default: $SERVER_PATH)
EOF
}

# --- Main ---

main() {
  check_dependencies

  local command="${1:-}"

  # Handle flags passed as first argument (e.g. `atelier -all`)
  if [[ "$command" == "-all" ]]; then
    cmd_interactive_launch "-all"
    exit 0
  fi

  # Default to interactive launch if no command provided
  if [[ -z "$command" ]]; then
    cmd_interactive_launch
    exit 0
  fi

  shift || true # Remove command from args

  case "$command" in
  launch)
    cmd_interactive_launch "$@"
    ;;
  direct)
    cmd_direct_launch "$@"
    ;;
  help | --help | -h)
    usage
    ;;
  *)
    log_error "Unknown command: $command"
    usage
    exit 1
    ;;
  esac
}

main "$@"
